    <script>
        /* ===== 模块级导航切换 ===== */
        function switchModule(module) {
            document.getElementById('module-events').style.display = 'none';
            document.getElementById('module-metrics').style.display = 'none';
            document.querySelectorAll('.sidebar-item').forEach(function(el) { el.classList.remove('active'); });

            if (module === 'events') {
                document.getElementById('module-events').style.display = 'block';
                document.getElementById('nav-module-events').classList.add('active');
                document.getElementById('nav-events-sub').style.display = 'block';
            } else if (module === 'metrics') {
                document.getElementById('module-metrics').style.display = 'block';
                document.getElementById('nav-module-metrics').classList.add('active');
                document.getElementById('nav-events-sub').style.display = 'none';
            }
        }

        /* ===== 事件管理 Tab 切换 ===== */
        function switchTab(type) {
            switchModule('events');
            document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
            document.querySelectorAll('.sidebar-sub-item').forEach(function(t) { t.classList.remove('active'); });
            document.querySelectorAll('.content-panel').forEach(function(p) { p.style.display = 'none'; });

            if (type === 'processed') {
                document.getElementById('tab-processed').classList.add('active');
                document.getElementById('nav-processed').classList.add('active');
                document.getElementById('content-processed').style.display = 'block';
            } else {
                document.getElementById('tab-tracking').classList.add('active');
                document.getElementById('nav-tracking').classList.add('active');
                document.getElementById('content-tracking').style.display = 'block';
            }
        }

        /* ===== 事件管理弹窗 ===== */
        function openSyncModal() {
            document.getElementById('syncModal').classList.add('show');
        }
        function closeSyncModal() {
            document.getElementById('syncModal').classList.remove('show');
        }
        function openDetailModal(name) {
            document.getElementById('detailModal').classList.add('show');
        }
        function closeDetailModal() {
            document.getElementById('detailModal').classList.remove('show');
        }

        function toggleVisibility(el) {
            var row = el.closest('tr');
            var statusTag = row.querySelectorAll('td')[4].querySelector('.tag');
            if (statusTag.textContent === '显示') {
                statusTag.textContent = '隐藏';
                statusTag.className = 'tag tag-hidden';
                el.textContent = '显示';
            } else {
                statusTag.textContent = '显示';
                statusTag.className = 'tag tag-visible';
                el.textContent = '隐藏';
            }
        }

        /* ===== 上传事件页面 ===== */
        function openUploadEventPage() {
            document.getElementById('content-processed').style.display = 'none';
            document.getElementById('page-upload-event').style.display = 'block';
        }
        function closeUploadEventPage() {
            document.getElementById('page-upload-event').style.display = 'none';
            document.getElementById('content-processed').style.display = 'block';
        }
        /* ===== 删除字段确认弹窗 ===== */
        function openDeleteConfirm() {
            document.getElementById('deleteConfirm').classList.add('show');
            var collapsed = document.getElementById('refListCollapsed');
            collapsed.classList.remove('show');
            document.getElementById('refToggleBtn').innerHTML = '展开更多（5个）▼';
        }
        function closeDeleteConfirm() {
            document.getElementById('deleteConfirm').classList.remove('show');
        }
        function toggleRefList() {
            var collapsed = document.getElementById('refListCollapsed');
            var btn = document.getElementById('refToggleBtn');
            if (collapsed.classList.contains('show')) {
                collapsed.classList.remove('show');
                btn.innerHTML = '展开更多（5个）▼';
            } else {
                collapsed.classList.add('show');
                btn.innerHTML = '收起 ▲';
            }
        }

        /* ===== 指标分组折叠 ===== */
        function toggleGroup(group) {
            var rows = document.querySelectorAll('.group-' + group);
            var arrow = document.getElementById('arrow-' + group);
            var isCollapsed = arrow.classList.contains('collapsed');
            rows.forEach(function(r) {
                if (isCollapsed) {
                    r.classList.remove('collapsed');
                } else {
                    r.classList.add('collapsed');
                }
            });
            arrow.classList.toggle('collapsed');
        }

        /* ===== 指标创建页面 ===== */
        function openCreateMetricModal() {
            document.getElementById('module-metrics').style.display = 'none';
            document.getElementById('page-create-metric').style.display = 'block';
        }
        function closeCreateMetricPage() {
            document.getElementById('page-create-metric').style.display = 'none';
            document.getElementById('module-metrics').style.display = 'block';
        }

        function updateCounter(inputId, counterId, max) {
            var len = document.getElementById(inputId).value.length;
            var counter = document.getElementById(counterId);
            counter.textContent = len;
            counter.style.color = len >= max ? '#ff4d4f' : '#bfbfbf';
        }

        function onLevelChange() {
            var level = document.getElementById('createMetricLevel').value;
            var el = document.getElementById('projectSelectGroup');
            el.style.display = (level === 'group') ? 'flex' : 'none';
        }

        function onScenarioChange() {
            var sel = document.getElementById('scenarioSelect');
            if (sel.value === '__new__') {
                document.getElementById('newScenarioInput').style.display = 'block';
                sel.value = '';
            }
        }
        function addNewScenario() {
            var name = document.getElementById('newScenarioName').value.trim();
            if (!name) return;
            var sel = document.getElementById('scenarioSelect');
            var opt = document.createElement('option');
            opt.value = name;
            opt.textContent = name + '（默认分组）';
            sel.insertBefore(opt, sel.querySelector('option[value="__new__"]'));
            sel.value = name;
            document.getElementById('newScenarioInput').style.display = 'none';
            document.getElementById('newScenarioName').value = '';
        }
        function cancelNewScenario() {
            document.getElementById('newScenarioInput').style.display = 'none';
            document.getElementById('newScenarioName').value = '';
            document.getElementById('scenarioSelect').value = '';
        }

        var _metricEditSource = 'view';
        var _metricLevelKey = 'personal';

        function populateViewPage(row) {
            var cells = row.querySelectorAll('td');
            var cnName = cells[0].textContent.trim();
            var enName = cells[1].textContent.trim();
            var scenario = cells[2].textContent.trim();
            var metricType = cells[3].textContent.trim();
            var createMethod = cells[4].textContent.trim();
            var subject = cells[5].textContent.trim();
            var creator = cells[6].textContent.trim();
            var updater = cells[7].textContent.trim();
            var updateTime = cells[8].textContent.trim();
            var formula = row.getAttribute('data-formula') || '—';

            var levelTag = '个人'; var levelClass = 'tag-level-personal'; var levelText = '个人 — 仅自己可见和修改'; _metricLevelKey = 'personal';
            if (row.classList.contains('group-company')) { levelTag = '公司级'; levelClass = 'tag-level-company'; levelText = '公司级 — 全员可见，仅管理员可修改'; _metricLevelKey = 'company'; }
            else if (row.classList.contains('group-group')) { levelTag = '项目组'; levelClass = 'tag-level-group'; levelText = '项目组 — 项目组成员可见和修改'; _metricLevelKey = 'group'; }
            else if (row.classList.contains('group-shared')) { levelTag = '分享'; levelClass = 'tag-shared'; levelText = '他人分享 — 可查看使用，不可修改'; _metricLevelKey = 'shared'; }

            document.getElementById('viewMetricPageTitle').textContent = cnName;
            document.getElementById('viewMetricLevelTag').textContent = levelTag;
            document.getElementById('viewMetricLevelTag').className = 'tag ' + levelClass;
            document.getElementById('viewCreateMethod').textContent = createMethod;
            document.getElementById('viewSubject').textContent = subject;
            document.getElementById('viewScenario').textContent = scenario;
            document.getElementById('viewLevel').textContent = levelText;
            document.getElementById('viewFormula').textContent = formula;
            document.getElementById('viewCnName').textContent = cnName;
            document.getElementById('viewEnName').textContent = enName;
            document.getElementById('viewCnDesc').textContent = '—';
            document.getElementById('viewEnDesc').textContent = '—';
            document.getElementById('viewMetricType').textContent = metricType;
            document.getElementById('viewCreator').textContent = creator;
            document.getElementById('viewUpdater').textContent = updater;
            document.getElementById('viewUpdateTime').textContent = updateTime;

            document.getElementById('editCreateMethod').value = createMethod;
            document.getElementById('editSubject').value = subject;
            document.getElementById('editScenario').value = scenario;
            document.getElementById('editLevel').value = _metricLevelKey;
            document.getElementById('editFormula').value = formula;
            document.getElementById('editCnName').value = cnName;
            document.getElementById('editEnName').value = enName;
            document.getElementById('editCnDesc').value = '';
            document.getElementById('editEnDesc').value = '';

            var projectRow = document.getElementById('viewProjectRow');
            if (row.classList.contains('group-group')) {
                var subHeader = row.previousElementSibling;
                while (subHeader && !subHeader.classList.contains('sub-group-header')) { subHeader = subHeader.previousElementSibling; }
                if (subHeader) {
                    var projName = subHeader.querySelector('.sub-group-name');
                    var pn = projName ? projName.textContent : '—';
                    document.getElementById('viewProject').textContent = pn;
                    document.getElementById('editProject').value = pn;
                    projectRow.style.display = 'flex';
                } else { projectRow.style.display = 'none'; }
            } else { projectRow.style.display = 'none'; }
        }

        function setViewMode() {
            document.getElementById('viewModeActions').style.display = '';
            document.getElementById('editModeActions').style.display = 'none';
            var page = document.getElementById('page-view-metric');
            page.querySelectorAll('.view-el').forEach(function(el) { el.style.display = ''; });
            page.querySelectorAll('.edit-el').forEach(function(el) { el.style.display = 'none'; });
        }

        function setEditMode() {
            document.getElementById('viewModeActions').style.display = 'none';
            document.getElementById('editModeActions').style.display = '';
            var page = document.getElementById('page-view-metric');
            page.querySelectorAll('.view-el').forEach(function(el) { el.style.display = 'none'; });
            page.querySelectorAll('.edit-el').forEach(function(el) { el.style.display = ''; });
            onEditLevelChange();
        }

        function openMetricDetail(el) {
            var row = el.closest('tr');
            if (!row) return;
            _metricEditSource = 'view';
            populateViewPage(row);
            setViewMode();
            document.getElementById('module-metrics').style.display = 'none';
            document.getElementById('page-view-metric').style.display = 'block';
        }

        function openMetricEdit(el) {
            var row = el.closest('tr');
            if (!row) return;
            _metricEditSource = 'list';
            populateViewPage(row);
            setEditMode();
            document.getElementById('module-metrics').style.display = 'none';
            document.getElementById('page-view-metric').style.display = 'block';
        }

        function enterEditMode() {
            _metricEditSource = 'view';
            setEditMode();
        }

        function cancelMetricEdit() {
            if (document.getElementById('editModeActions').style.display !== 'none') {
                if (_metricEditSource === 'list') {
                    document.getElementById('page-view-metric').style.display = 'none';
                    document.getElementById('module-metrics').style.display = 'block';
                    return;
                }
                setViewMode();
                return;
            }
            document.getElementById('page-view-metric').style.display = 'none';
            document.getElementById('module-metrics').style.display = 'block';
        }

        function onEditLevelChange() {
            var lv = document.getElementById('editLevel').value;
            var pr = document.getElementById('viewProjectRow');
            pr.style.display = (lv === 'group') ? 'flex' : 'none';
        }

        function showSaveConfirm() {
            document.getElementById('saveMetricConfirm').classList.add('show');
        }
        function closeSaveConfirm() {
            document.getElementById('saveMetricConfirm').classList.remove('show');
        }
        function confirmSaveMetric() {
            closeSaveConfirm();
            document.getElementById('page-view-metric').style.display = 'none';
            document.getElementById('module-metrics').style.display = 'block';
        }

        function openShareModal() {
            document.getElementById('shareModal').classList.add('show');
        }
        function closeShareModal() {
            document.getElementById('shareModal').classList.remove('show');
        }

        function toggleMetricStatus(el) {
            var row = el.closest('tr');
            var cells = row.querySelectorAll('td');
            var statusTag = null;
            for (var i = 0; i < cells.length; i++) {
                var tag = cells[i].querySelector('.tag-online, .tag-offline, .tag-draft');
                if (tag) { statusTag = tag; break; }
            }
            if (!statusTag) return;
            if (statusTag.textContent === '已上线') {
                statusTag.textContent = '已下线';
                statusTag.className = 'tag tag-offline';
                el.textContent = '上线';
            } else {
                statusTag.textContent = '已上线';
                statusTag.className = 'tag tag-online';
                el.textContent = '下线';
            }
        }

        /* ===== 指标表格：点击名称/查看/编辑 ===== */
        document.getElementById('metricTable').addEventListener('click', function(e) {
            var target = e.target;
            if (target.classList.contains('link') && target.closest('.group-row') && !target.closest('.group-header')) {
                openMetricDetail(target);
                return;
            }
            if (target.classList.contains('icon-btn') && target.textContent.trim() === '查看') {
                openMetricDetail(target);
                return;
            }
            if (target.classList.contains('icon-btn') && target.textContent.trim() === '编辑') {
                openMetricEdit(target);
                return;
            }
        });

        /* ===== 点击遮罩关闭弹窗 ===== */
        document.querySelectorAll('.modal-overlay, .confirm-overlay').forEach(function(overlay) {
            overlay.addEventListener('click', function(e) {
                if (e.target === this) {
                    this.classList.remove('show');
                }
            });
        });
    </script>
    </div><!-- /page-wrapper -->
</body>
</html>
