/* ===== 拖拽分割线 ===== */
(function() {
    var handle = document.getElementById('resizeHandle');
    var panel = document.querySelector('.left-panel');
    var startX, startW;

    handle.addEventListener('mousedown', function(e) {
        e.preventDefault();
        startX = e.clientX;
        startW = panel.offsetWidth;
        handle.classList.add('dragging');
        document.body.classList.add('resizing');
        document.addEventListener('mousemove', onDrag);
        document.addEventListener('mouseup', stopDrag);
    });

    function onDrag(e) {
        var newW = startW + (e.clientX - startX);
        var min = parseInt(getComputedStyle(panel).minWidth) || 200;
        var max = parseInt(getComputedStyle(panel).maxWidth) || 500;
        if (newW < min) newW = min;
        if (newW > max) newW = max;
        panel.style.width = newW + 'px';
    }

    function stopDrag() {
        handle.classList.remove('dragging');
        document.body.classList.remove('resizing');
        document.removeEventListener('mousemove', onDrag);
        document.removeEventListener('mouseup', stopDrag);
    }
})();

