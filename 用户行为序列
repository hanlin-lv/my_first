<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>用户行为序列 - 行为聚焦交互重设计</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', sans-serif; background: #fff; color: #1a1a1a; }

        /* ===== 顶部导航栏 ===== */
        .global-nav {
            height: 48px; flex-shrink: 0;
            background: linear-gradient(90deg, #d94145 0%, #c43a5e 25%, #a93478 50%, #8a2e8a 75%, #6b2fa0 100%);
            display: flex; align-items: center;
            padding: 0 20px; gap: 0;
            box-shadow: 0 1px 4px rgba(0,0,0,.2);
            z-index: 200; position: relative;
        }
        .global-nav-logo {
            font-size: 15px; font-weight: 700; color: #fff;
            margin-right: 28px; white-space: nowrap; letter-spacing: .5px;
            display: flex; align-items: center; gap: 8px;
            text-decoration: none;
        }
        .global-nav-logo img { height: 32px; }
        .global-nav-logo svg { height: 22px; width: auto; }
        .nav-items { display: flex; align-items: center; flex: 1; gap: 0; }
        .nav-item {
            padding: 0 16px; height: 48px;
            display: flex; align-items: center; gap: 5px;
            font-size: 14px; color: rgba(255,255,255,.75);
            cursor: pointer; position: relative;
            transition: color .15s; white-space: nowrap;
            text-decoration: none; user-select: none;
        }
        .nav-item:hover { color: #fff; }
        .nav-item.active { color: #fff; font-weight: 600; }
        .nav-item.active::after {
            content: ''; position: absolute; bottom: 0; left: 12px; right: 12px;
            height: 3px; background: #fff; border-radius: 2px 2px 0 0;
        }
        .nav-item-icon { display: flex; align-items: center; font-size: 15px; }
        .nav-item-arrow { font-size: 10px; opacity: .7; margin-left: 2px; }
        .nav-item .nav-dropdown { display: none; }
        .nav-item:hover .nav-dropdown { display: block; }
        .nav-dropdown {
            position: absolute; top: 48px; left: 0;
            background: #fff; border-radius: 6px;
            box-shadow: 0 4px 16px rgba(0,0,0,.15);
            min-width: 160px; padding: 6px 0; z-index: 300;
        }
        .nav-dropdown a {
            display: block; padding: 8px 18px; font-size: 13px;
            color: #333; text-decoration: none; transition: background .1s;
            white-space: nowrap;
        }
        .nav-dropdown a:hover { background: #f5f0ff; color: #722ed1; }
        .nav-dropdown a.active { color: #722ed1; font-weight: 600; background: #f9f0ff; }
        .nav-right {
            display: flex; align-items: center; gap: 16px;
            margin-left: auto; color: rgba(255,255,255,.8); font-size: 13px;
        }
        .nav-right-icon {
            width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;
            cursor: pointer; border-radius: 50%; transition: background .15s;
        }
        .nav-right-icon:hover { background: rgba(255,255,255,.15); }
        .nav-user {
            display: flex; align-items: center; gap: 6px;
            cursor: pointer; padding: 4px 8px; border-radius: 4px;
        }
        .nav-user:hover { background: rgba(255,255,255,.1); }
        .nav-avatar {
            width: 26px; height: 26px; border-radius: 50%;
            background: rgba(255,255,255,.25); display: flex;
            align-items: center; justify-content: center;
            font-size: 11px; color: #fff; font-weight: 600;
        }

        /* ===== 整体布局 ===== */
        .page-wrapper { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
        .layout { display: flex; flex: 1; overflow: hidden; }

        /* ===== 左侧用户面板 ===== */
        .left-panel {
            width: 272px; min-width: 200px; max-width: 500px; flex-shrink: 0;
            display: flex; flex-direction: column;
            background: #fff;
            overflow: hidden;
        }

        /* ===== 可拖拽分割线 ===== */
        .resize-handle {
            width: 4px; flex-shrink: 0; cursor: col-resize;
            background: #e8e8e8; position: relative; z-index: 10;
            transition: background .15s;
        }
        .resize-handle::after {
            content: ''; position: absolute; top: 0; bottom: 0; left: -3px; right: -3px;
        }
        .resize-handle:hover, .resize-handle.dragging { background: #b37feb; }
        body.resizing { cursor: col-resize; user-select: none; }
        body.resizing .left-panel, body.resizing .right-main { pointer-events: none; }
        .left-header {
            padding: 14px 16px 0;
            border-bottom: 1px solid #f0f0f0;
        }
        .left-title {
            display: flex; align-items: center; gap: 8px;
            font-size: 14px; font-weight: 600; color: #262626;
            margin-bottom: 12px;
        }
        .left-title-icon {
            width: 20px; height: 20px; border-radius: 4px;
            background: #531dab; color: #fff;
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700;
        }
        .project-tabs {
            display: flex; align-items: center; gap: 0; margin-bottom: 0;
        }
        .project-tab {
            padding: 6px 12px; font-size: 12px; color: #8c8c8c;
            cursor: pointer; border-bottom: 2px solid transparent;
            transition: all .15s; white-space: nowrap;
        }
        .project-tab:hover { color: #531dab; }
        .project-tab.active { color: #531dab; font-weight: 600; border-bottom-color: #531dab; }
        .project-more { font-size: 11px; color: #bfbfbf; cursor: pointer; padding: 6px 4px; }

        .user-id-section { padding: 12px 16px; border-bottom: 1px solid #f0f0f0; }
        .uid-tabs { display: flex; gap: 0; margin-bottom: 8px; }
        .uid-tab {
            padding: 4px 12px; font-size: 12px; color: #8c8c8c;
            cursor: pointer; border: 1px solid #d9d9d9; background: #fff;
            transition: all .15s;
        }
        .uid-tab:first-child { border-radius: 4px 0 0 4px; }
        .uid-tab:last-child { border-radius: 0 4px 4px 0; border-left: none; }
        .uid-tab.active { background: #531dab; color: #fff; border-color: #531dab; }
        .uid-tab.active + .uid-tab { border-left: 1px solid #d9d9d9; }
        .uid-input-row { display: flex; gap: 6px; }
        .uid-input {
            flex: 1; padding: 5px 10px; border: 1px solid #d9d9d9; border-radius: 4px;
            font-size: 12px; outline: none;
        }
        .uid-input:focus { border-color: #531dab; }
        .btn-green { padding: 5px 14px; border-radius: 4px; font-size: 12px; cursor: pointer; border: none; background: #52c41a; color: #fff; font-weight: 500; }
        .btn-green:hover { background: #73d13d; }

        .user-info-header {
            display: flex; align-items: center; gap: 8px;
            padding: 10px 16px; border-bottom: 1px solid #f0f0f0;
        }
        .info-tab { font-size: 12px; color: #262626; font-weight: 500; padding: 3px 0; border-bottom: 2px solid #531dab; cursor: pointer; }
        .info-btn {
            padding: 2px 8px; border: 1px solid #d9d9d9; border-radius: 4px;
            font-size: 11px; color: #595959; cursor: pointer; background: #fff;
        }
        .info-btn:hover { border-color: #531dab; color: #531dab; }

        .user-info-body {
            flex: 1; overflow-y: auto; padding: 0;
        }
        .info-row {
            display: flex; align-items: center; justify-content: space-between;
            padding: 7px 16px; border-bottom: 1px solid #f8f8f8;
            font-size: 12px;
        }
        .info-row:hover { background: #fafafa; }
        .info-key { color: #595959; flex-shrink: 0; max-width: 130px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .info-val { color: #262626; text-align: right; font-weight: 500; max-width: 130px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

        /* ===== 右侧主内容区 ===== */
        .right-main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

        .top-toolbar {
            padding: 10px 20px;
            border-bottom: 1px solid #f0f0f0;
            background: #fff;
            flex-shrink: 0;
        }
        .toolbar-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
        .toolbar-row + .toolbar-row { margin-top: 10px; }
        .tb-item { display: inline-flex; align-items: center; gap: 5px; font-size: 12px; color: #595959; }
        .tb-item select, .tb-item input[type="text"] {
            padding: 4px 8px; border: 1px solid #d9d9d9; border-radius: 4px; font-size: 12px; outline: none;
        }
        .tb-item select:focus, .tb-item input:focus { border-color: #531dab; }
        .tb-sep { width: 1px; height: 22px; background: #e8e8e8; }
        .btn-purple { padding: 5px 16px; border-radius: 4px; font-size: 12px; cursor: pointer; border: none; background: #531dab; color: #fff; font-weight: 500; }
        .btn-purple:hover { background: #722ed1; }
        .btn-outline { padding: 5px 12px; border-radius: 4px; font-size: 12px; cursor: pointer; border: 1px solid #d9d9d9; background: #fff; color: #595959; }
        .btn-outline:hover { border-color: #531dab; color: #531dab; }

        .sort-btn {
            display: inline-flex; align-items: center; gap: 4px;
            padding: 4px 10px; border: 1px solid #d9d9d9; border-radius: 4px;
            font-size: 12px; color: #595959; cursor: pointer; background: #fff;
        }
        .sort-btn:hover { border-color: #531dab; color: #531dab; }
        .sort-arrows { display: inline-flex; flex-direction: column; line-height: 1; font-size: 8px; gap: 0; }
        .sort-arrows span { opacity: .3; }
        .sort-arrows span.active { opacity: 1; color: #531dab; }

        /* ★ 聚焦事件按钮 */
        .focus-btn {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 4px 12px; border: 1px solid #d9d9d9; border-radius: 4px;
            font-size: 12px; color: #595959; cursor: pointer; background: #fff;
            transition: all .15s; position: relative;
        }
        .focus-btn:hover { border-color: #531dab; color: #531dab; }
        .focus-btn.has-focus { border-color: #531dab; color: #531dab; background: #f9f0ff; }
        .focus-btn-icon { font-size: 13px; }

        .btn-clear-x {
            position: absolute; top: -7px; right: -7px;
            width: 16px; height: 16px; border-radius: 50%;
            background: #8c8c8c; color: #fff;
            display: none; align-items: center; justify-content: center;
            font-size: 10px; line-height: 1; cursor: pointer;
            border: 1.5px solid #fff; z-index: 2;
            transition: background .1s;
        }
        .btn-clear-x:hover { background: #ff4d4f; }
        .focus-btn.has-focus:hover .btn-clear-x { display: flex; }
        .locate-btn.has-locate:hover .btn-clear-x { display: flex; }

        .tb-log-count { font-size: 12px; color: #8c8c8c; margin-left: auto; }

        /* ★ 定位事件按钮 */
        .locate-btn {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 4px 12px; border: 1px solid #d9d9d9; border-radius: 4px;
            font-size: 12px; color: #595959; cursor: pointer; background: #fff;
            transition: all .15s; position: relative;
        }
        .locate-btn:hover { border-color: #1890ff; color: #1890ff; }
        .locate-btn.has-locate { border-color: #1890ff; color: #1890ff; background: #e6f7ff; }

        /* 定位导航器 < 1/13 > */
        .locate-nav {
            display: none; align-items: center; gap: 2px; font-size: 12px; color: #262626;
            user-select: none;
        }
        .locate-nav.show { display: inline-flex; }
        .locate-nav-arrow {
            width: 22px; height: 22px; border-radius: 4px;
            display: inline-flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 13px; color: #595959;
            transition: all .1s; border: none; background: none; padding: 0;
        }
        .locate-nav-arrow:hover { background: #e6f7ff; color: #1890ff; }
        .locate-nav-arrow.disabled { color: #d9d9d9; cursor: default; }
        .locate-nav-arrow.disabled:hover { background: none; }
        .locate-nav-text { padding: 0 4px; font-family: 'SF Mono','Monaco','Menlo',monospace; color: #1890ff; font-weight: 600; }

        /* 定位高亮：仅当前跳转到的事件 */
        .tl-entry.located-current { background: #bae7ff; }
        .tl-entry.located-current .tl-dot { background: #1890ff; box-shadow: 0 0 0 4px rgba(24,144,255,0.35); }

        /* 定位抽屉使用蓝色主题 */
        .drawer.locate-drawer .drawer-back:hover { color: #1890ff; }
        .drawer.locate-drawer .btn-confirm { background: #1890ff; }
        .drawer.locate-drawer .btn-confirm:hover { background: #40a9ff; }
        .drawer.locate-drawer .ev-row-num { background: #e6f7ff; color: #1890ff; }
        .drawer.locate-drawer .ev-row-select.has-value { color: #262626; }
        .drawer.locate-drawer .ev-action-filter.active { color: #1890ff; background: #e6f7ff; }
        .drawer.locate-drawer .ev-action-filter:hover { color: #1890ff; background: #e6f7ff; }
        .drawer.locate-drawer .ev-dropdown-item.selected { color: #1890ff; background: #e6f7ff; }
        .drawer.locate-drawer .ev-dropdown-item:hover { background: #e6f7ff; }
        .drawer.locate-drawer .ev-filter-bracket { border-left-color: #91d5ff; }
        .drawer.locate-drawer .btn-cancel:hover { border-color: #1890ff; color: #1890ff; }

        /* ===== 时间线序列区 ===== */
        .timeline-area { flex: 1; overflow-y: auto; background: #fff; position: relative; }

        /* ===== 加载更多 ===== */
        .load-more-bar {
            padding: 16px 20px; text-align: center;
            border-top: 1px solid #f0f0f0;
        }
        .load-more-btn {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 8px 32px; border-radius: 6px; font-size: 13px;
            cursor: pointer; border: 1px solid #d9d9d9; background: #fff;
            color: #595959; transition: all .15s;
        }
        .load-more-btn:hover { border-color: #531dab; color: #531dab; background: #f9f0ff; }
        .load-more-btn:active { transform: scale(0.98); }
        .load-more-btn.loading { pointer-events: none; color: #bfbfbf; }
        .load-more-hint { font-size: 11px; color: #bfbfbf; margin-top: 6px; }
        .load-more-done { padding: 20px; text-align: center; font-size: 12px; color: #bfbfbf; }
        .tz-label { padding: 6px 20px; font-size: 11px; color: #8c8c8c; background: #fafafa; border-bottom: 1px solid #f0f0f0; }
        .date-header { padding: 10px 20px; font-size: 14px; font-weight: 600; color: #262626; background: #fafafa; border-bottom: 1px solid #f0f0f0; }
        .tl-entry {
            display: flex; align-items: stretch; border-bottom: 1px solid #f5f5f5;
            transition: background .1s; cursor: pointer;
        }
        .tl-entry:hover { background: #fafafa; }
        .tl-entry.focused { }
        .tl-time {
            width: 80px; flex-shrink: 0; padding: 12px 0 12px 20px;
            font-size: 12px; color: #8c8c8c; font-family: 'SF Mono','Monaco','Menlo', monospace;
        }
        .tl-dot-col {
            width: 36px; flex-shrink: 0; display: flex; align-items: center; justify-content: center;
            position: relative;
        }
        .tl-dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: #531dab; position: relative; z-index: 1;
        }
        .tl-dot.ev-app-launch { background: #531dab; }
        .tl-dot.ev-click-detail { background: #531dab; }
        .tl-dot.ev-game-end { background: #531dab; }
        .tl-dot.ev-match-start { background: #531dab; }
        .tl-dot-col::before {
            content: ''; position: absolute; top: 0; bottom: 0; left: 50%;
            width: 1px; background: #e8e8e8; transform: translateX(-50%);
        }
        .tl-entry:first-of-type .tl-dot-col::before { top: 50%; }
        .tl-entry:last-of-type .tl-dot-col::before { bottom: 50%; }
        .tl-content {
            flex: 1; padding: 10px 16px 10px 0;
            display: flex; align-items: center; gap: 8px;
        }
        .tl-expand {
            font-size: 11px; color: #595959; cursor: pointer;
            transition: transform .2s; flex-shrink: 0;
        }
        .tl-expand.open { transform: rotate(90deg); }
        .tl-event-name { font-size: 13px; color: #262626; }
        .tl-event-tag {
            font-size: 10px; padding: 1px 6px; border-radius: 3px;
            background: #f9f0ff; color: #722ed1; white-space: nowrap;
            display: none;
        }
        .tl-entry.focused .tl-event-tag { }
        .tl-detail {
            display: none; padding: 0 16px 12px 116px;
            font-size: 12px; color: #8c8c8c; line-height: 1.8;
            border-bottom: 1px solid #f5f5f5;
        }
        .tl-detail.open { display: block; }
        .tl-detail-table { width: 100%; max-width: 500px; }
        .tl-detail-table td { padding: 2px 8px 2px 0; vertical-align: top; }
        .tl-detail-table td:first-child { color: #8c8c8c; white-space: nowrap; width: 120px; }
        .tl-detail-table td:last-child { color: #262626; }



        /* ===== 右侧抽屉 ===== */
        .drawer-overlay {
            display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.35); z-index: 500;
        }
        .drawer-overlay.show { display: block; }
        .drawer {
            position: fixed; top: 0; right: -520px; width: 520px; height: 100vh;
            background: #fff; z-index: 600;
            box-shadow: -4px 0 24px rgba(0,0,0,0.1);
            display: flex; flex-direction: column;
            transition: right .28s cubic-bezier(0.23,1,0.32,1);
        }
        .drawer.open { right: 0; }

        .drawer-header {
            padding: 20px 24px 16px;
            border-bottom: 1px solid #f0f0f0;
            flex-shrink: 0;
        }
        .drawer-title {
            display: flex; align-items: center; gap: 8px;
            font-size: 16px; font-weight: 600; color: #262626;
        }
        .drawer-back {
            font-size: 18px; color: #595959; cursor: pointer; text-decoration: none;
            display: inline-flex; align-items: center; margin-right: 2px;
            transition: color .15s;
        }
        .drawer-back:hover { color: #531dab; }

        .drawer-body { flex: 1; overflow-y: auto; padding: 24px 24px 16px; }

        /* ===== 事件行列表 ===== */
        .ev-row { margin-bottom: 20px; }

        .ev-row-main {
            display: flex; align-items: center; gap: 10px;
        }
        .ev-row-num {
            width: 28px; height: 28px; border-radius: 6px;
            background: #f0f0f0; color: #595959;
            display: flex; align-items: center; justify-content: center;
            font-size: 13px; font-weight: 600; flex-shrink: 0;
        }
        .ev-row-select {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 6px 12px; border: 1px solid #e8e8e8; border-radius: 6px;
            background: #fff; cursor: pointer; font-size: 13px; color: #262626;
            transition: all .15s; position: relative; min-width: 140px;
        }
        .ev-row-select:hover { border-color: #b37feb; }
        .ev-row-select.has-value { color: #262626; font-weight: 500; }
        .ev-row-select.placeholder { color: #bfbfbf; }
        .ev-row-select-icon {
            display: inline-flex; align-items: center; justify-content: center;
            width: 18px; height: 18px; flex-shrink: 0;
        }
        .ev-row-select-arrow { font-size: 10px; color: #bfbfbf; margin-left: auto; }

        .ev-row-actions {
            display: flex; align-items: center; gap: 6px; margin-left: auto;
        }
        .ev-action-btn {
            display: inline-flex; align-items: center; gap: 4px;
            padding: 4px 10px; border-radius: 4px;
            font-size: 12px; cursor: pointer; transition: all .15s;
            border: none; background: none;
        }
        .ev-action-filter { color: #8c8c8c; }
        .ev-action-filter:hover { color: #531dab; background: #f9f0ff; }
        .ev-action-filter.active { color: #531dab; background: #f9f0ff; }
        .ev-action-filter-icon { font-size: 12px; }
        .ev-action-delete { color: #8c8c8c; }
        .ev-action-delete:hover { color: #ff4d4f; background: #fff1f0; }

        /* 事件选择下拉面板 */
        .ev-dropdown {
            display: none; position: absolute; top: calc(100% + 4px); left: 0;
            min-width: 200px; max-height: 220px; overflow-y: auto;
            background: #fff; border: 1px solid #e8e8e8; border-radius: 8px;
            box-shadow: 0 4px 16px rgba(0,0,0,0.1); z-index: 10;
            padding: 4px 0;
        }
        .ev-dropdown.show { display: block; }
        .ev-dropdown-item {
            padding: 8px 14px; font-size: 13px; color: #262626;
            cursor: pointer; display: flex; align-items: center; gap: 8px;
            transition: background .1s;
        }
        .ev-dropdown-item:hover { background: #f9f0ff; }
        .ev-dropdown-item.selected { color: #531dab; font-weight: 500; background: #f9f0ff; }
        .ev-dropdown-item.disabled { color: #d9d9d9; cursor: not-allowed; }
        .ev-dropdown-item.disabled:hover { background: transparent; }
        .ev-dropdown-item-icon {
            width: 18px; height: 18px; display: inline-flex;
            align-items: center; justify-content: center;
        }

        /* 筛选条件展开区 */
        .ev-filter-area {
            display: none; margin-top: 10px; padding-left: 38px;
        }
        .ev-filter-area.show { display: block; }
        .ev-filter-bracket {
            border-left: 2px solid #e8e8e8; padding-left: 16px; padding-bottom: 4px;
        }
        .ev-filter-row {
            display: flex; align-items: center; gap: 6px; margin-bottom: 8px;
        }
        .ev-filter-row select, .ev-filter-row input {
            padding: 6px 10px; border: 1px solid #e8e8e8; border-radius: 6px;
            font-size: 12px; outline: none; background: #fff; transition: border .15s;
        }
