}

function computeLocateMatches() {
    _locateMatchIndices = [];
    if (appliedLocateEvents.length === 0) return;
    _filteredData.forEach(function(d, i) {
        if (appliedLocateEvents.indexOf(d.id) < 0) return;
        var evFilters = appliedLocateFilters[d.id];
        if (evFilters && evFilters.length > 0) {
            var pass = evFilters.every(function(f) {
                if (!f.attr || !f.value) return true;
                var propVal = d.props[f.attr] || '';
                if (f.op === '=') return propVal === f.value;
                if (f.op === '!=') return propVal !== f.value;
                if (f.op === '包含') return propVal.indexOf(f.value) >= 0;
                if (f.op === '不为空') return propVal !== '';
                return true;
            });
            if (!pass) return;
        }
        _locateMatchIndices.push(i);
    });
}

function updateLocateNav() {
    var nav = document.getElementById('locateNav');
    if (_locateMatchIndices.length === 0 && appliedLocateEvents.length === 0) {
        nav.classList.remove('show');
        return;
    }
    nav.classList.add('show');
    var total = _locateMatchIndices.length;
    var cur = total > 0 ? (_locateCurrentIdx + 1) : 0;
    document.getElementById('locateNavText').textContent = cur + '/' + total;
    document.getElementById('locatePrev').className = 'locate-nav-arrow' + (_locateCurrentIdx <= 0 ? ' disabled' : '');
    document.getElementById('locateNext').className = 'locate-nav-arrow' + (_locateCurrentIdx >= total - 1 ? ' disabled' : '');
}

function locateNavStep(dir) {
    if (_locateMatchIndices.length === 0) return;
    var next = _locateCurrentIdx + dir;
    if (next < 0 || next >= _locateMatchIndices.length) return;
    _locateCurrentIdx = next;
    updateLocateNav();
    jumpToLocateEntry(_locateMatchIndices[next]);
}

function jumpToLocateEntry(dataIdx) {
    ensureDataLoaded(dataIdx, function() {
        clearLocateHighlights();

        var entries = document.getElementById('timelineList').querySelectorAll('.tl-entry');
        var target = entries[dataIdx];
        if (!target) return;

        target.classList.add('located-current');

        var area = document.getElementById('timelineArea');
        var areaRect = area.getBoundingClientRect();
        var entryRect = target.getBoundingClientRect();
        var offset = entryRect.top - areaRect.top - (areaRect.height / 2) + (entryRect.height / 2);
        area.scrollTop += offset;
    });
}

function ensureDataLoaded(dataIdx, callback) {
    if (dataIdx < _displayedCount) {
        callback();
        return;
    }
    var needed = dataIdx + 1;
    while (_displayedCount < needed && _displayedCount < _filteredData.length) {
        var list = document.getElementById('timelineList');
        var isFocused = appliedEvents.length > 0;
        var end = Math.min(_displayedCount + PAGE_SIZE, _filteredData.length);
        var fragment = '';
        for (var i = _displayedCount; i < end; i++) {
            fragment += renderTimelineEntry(_filteredData[i], i, isFocused);
        }
        list.insertAdjacentHTML('beforeend', fragment);
        _displayedCount = end;
    }
    updateLoadMoreBar();
    requestAnimationFrame(callback);
}

function clearLocateHighlights() {
    document.querySelectorAll('.tl-entry.located-current').forEach(function(el) {
        el.classList.remove('located-current');
    });
}

