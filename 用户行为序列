    { id: 'button_click', name: '按钮点击' },
    { id: 'video_play', name: '视频播放' },
    { id: 'share_event', name: '分享事件' }
];

var ATTRS = ['platform', 'country', 'device_model', 'os_version', 'app_version', 'channel', 'network_type'];
var OPS = ['=', '!=', '包含', 'in', '不为空'];

var USER_INFO = [
    ['User ID', '117408072'],
    ['ADSET ID OR SITE ID', 'unknown'],
    ['包体id', '1000'],
    ['包体名称', 'Solitaire Clash'],
    ['APP_VERSION', '11.44'],
    ['注册国家（推荐）', 'US'],
    ['BONUS_BALANCE', '0.34'],
    ['Campaign', 'unknown'],
    ['CASH_BALANCE', '0.00'],
    ['最新cash+bonus账户余额', '0.34'],
    ['末次登录APP ID', '1000']
];

var EVENT_TEMPLATES = [
    { id: 'app_launch', event: 'APP启动退出', propsFn: function(i) {
        var types = ['cold','warm','exit']; return { launch_type: types[i%3], duration: types[i%3]==='exit'?'—':(1+Math.random()*3).toFixed(1)+'s', platform: i%4===0?'Android':'iOS', app_version: '11.44' };
    }},
    { id: 'click_detail', event: '位置点击详情', propsFn: function(i) {
        var pos = ['main_tab','banner_1','game_list','play_btn','in_game','result_screen','sidebar','settings','shop','profile'];
        var tgt = ['lobby','promo','solitaire','match','card_flip','play_again','back_lobby','undo','buy','avatar'];
        return { position: pos[i%pos.length], target: tgt[i%tgt.length], platform: i%5===0?'Android':'iOS' };
    }},
    { id: 'game_end', event: '游戏结束', propsFn: function(i) {
        return { result: i%3===0?'lose':'win', score: String(1200+Math.floor(Math.random()*1800)), duration: String(60+Math.floor(Math.random()*300))+'s' };
    }},
    { id: 'match_start', event: '比赛开始', propsFn: function(i) {
        var modes = ['ranked','casual','training']; return { mode: modes[i%3], region: 'NA', queue_time: String(2+Math.floor(Math.random()*15))+'s' };
    }}
];

function generateMockData(count) {
    var data = [];
    var h = 3, m = 50, s = 33;
    for (var i = 0; i < count; i++) {
        var tpl = EVENT_TEMPLATES[i % EVENT_TEMPLATES.length];
        var timeStr = String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
        data.push({ time: timeStr, event: tpl.event, id: tpl.id, props: tpl.propsFn(i) });
        s += 2 + Math.floor(Math.random() * 8);
        if (s >= 60) { s -= 60; m++; }
        if (m >= 60) { m -= 60; h++; }
    }
    return data;
}

var MOCK_TIMELINE = generateMockData(1000);

var PAGE_SIZE = 100;
var _filteredData = [];
var _displayedCount = 0;
var drawerRows = [];
var appliedEvents = [];
var appliedFilters = {};
var _openDropdownIdx = -1;

var EVENT_ICON_SVG = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 5l4-3 4 3M2 11l4 3 4-3M10 5l4 3-4 3"/></svg>';

function renderUserInfo() {
    var body = document.getElementById('userInfoBody');
    body.innerHTML = USER_INFO.map(function(row) {
        return '<div class="info-row"><span class="info-key">' + row[0] + '</span><span class="info-val">' + row[1] + '</span></div>';
    }).join('');
}

function getFilteredData(focusedIds) {
    var data = MOCK_TIMELINE;
    if (focusedIds && focusedIds.length > 0) {
        data = data.filter(function(d) {
            if (focusedIds.indexOf(d.id) < 0) return false;
            var evFilters = appliedFilters[d.id];
            if (evFilters && evFilters.length > 0) {
                return evFilters.every(function(f) {
                    if (!f.attr || !f.value) return true;
                    var propVal = d.props[f.attr] || '';
                    if (f.op === '=') return propVal === f.value;
                    if (f.op === '!=') return propVal !== f.value;
                    if (f.op === '包含') return propVal.indexOf(f.value) >= 0;
                    if (f.op === '不为空') return propVal !== '';
                    return true;
                });
            }
            return true;
        });
    }
    return data;
}

function renderTimelineEntry(d, globalIdx, isFocused) {
    var focused = isFocused ? ' focused' : '';
    var propsHtml = Object.keys(d.props).map(function(k) {
        return '<tr><td>' + k + '</td><td>' + d.props[k] + '</td></tr>';
    }).join('');
    return '<div class="tl-entry' + focused + '" onclick="toggleDetail(' + globalIdx + ')">'
        + '<div class="tl-time">' + d.time + '</div>'
        + '<div class="tl-dot-col"><div class="tl-dot ev-' + d.id.replace(/_/g, '-') + '"></div></div>'
        + '<div class="tl-content">'
        + '<span class="tl-expand" id="expand-' + globalIdx + '">▶</span>'
        + '<span class="tl-event-name">' + d.event + '</span>'
        + '<span class="tl-event-tag">' + d.event + '</span>'
        + '</div></div>'
        + '<div class="tl-detail" id="detail-' + globalIdx + '"><table class="tl-detail-table">' + propsHtml + '</table></div>';
}

function renderTimeline(focusedIds) {
    _filteredData = getFilteredData(focusedIds);
    _displayedCount = 0;
    var list = document.getElementById('timelineList');
    list.innerHTML = '';
    removeLoadMore();
    loadMoreItems();
    document.getElementById('logCount').textContent = '查询到' + _filteredData.length + '条日志记录';
    document.getElementById('timelineArea').scrollTop = 0;
    if (appliedLocateEvents.length > 0) {
        computeLocateMatches();
        _locateCurrentIdx = _locateMatchIndices.length > 0 ? 0 : -1;
        updateLocateNav();
    }
}

function loadMoreItems() {
    var list = document.getElementById('timelineList');
    var isFocused = appliedEvents.length > 0;
    var end = Math.min(_displayedCount + PAGE_SIZE, _filteredData.length);
    var fragment = '';
    for (var i = _displayedCount; i < end; i++) {
        fragment += renderTimelineEntry(_filteredData[i], i, isFocused);
    }
    list.insertAdjacentHTML('beforeend', fragment);
    _displayedCount = end;
    updateLoadMoreBar();
}

function updateLoadMoreBar() {
    removeLoadMore();
    var container = document.getElementById('timelineArea');
    var total = _filteredData.length;

    if (_displayedCount >= total) {
        if (total > PAGE_SIZE) {
            var done = document.createElement('div');
            done.className = 'load-more-done';
            done.id = 'loadMoreBar';
            done.textContent = '已展示全部 ' + total + ' 条记录';
            container.appendChild(done);
        }
        return;
    }

    var remaining = total - _displayedCount;
    var nextBatch = Math.min(remaining, PAGE_SIZE);
    var bar = document.createElement('div');
    bar.className = 'load-more-bar';
    bar.id = 'loadMoreBar';
    bar.innerHTML = '<button class="load-more-btn" onclick="onLoadMore()">查看更多</button>'
        + '<div class="load-more-hint">已展示 ' + _displayedCount + ' / ' + total + ' 条，点击加载下 ' + nextBatch + ' 条</div>';
    container.appendChild(bar);
}

function onLoadMore() {
    var btn = document.querySelector('.load-more-btn');
    if (btn) {
        btn.classList.add('loading');
        btn.textContent = '加载中...';
    }
    setTimeout(function() {
        loadMoreItems();
    }, 300);
}

function removeLoadMore() {
    var old = document.getElementById('loadMoreBar');
    if (old) old.remove();
}

function toggleDetail(i) {
    var detail = document.getElementById('detail-' + i);
    var arrow = document.getElementById('expand-' + i);
    if (detail && arrow) {
        detail.classList.toggle('open');
        arrow.classList.toggle('open');
    }
}

var _sortAsc = true;
function toggleSort() {
    _sortAsc = !_sortAsc;
    document.getElementById('sortLabel').textContent = _sortAsc ? '升序' : '降序';
    document.getElementById('sortUp').className = _sortAsc ? 'active' : '';
    document.getElementById('sortDown').className = _sortAsc ? '' : 'active';
    MOCK_TIMELINE.reverse();
    renderTimeline(appliedEvents.length > 0 ? appliedEvents : null);
}

/* ===== 抽屉 ===== */
function openDrawer() {
    drawerRows = [];
    appliedEvents.forEach(function(evId) {
        var conds = (appliedFilters[evId] || []).map(function(f) {
            return { attr: f.attr, op: f.op, value: f.value };
        });
        drawerRows.push({ eventId: evId, filters: conds, filterOpen: conds.length > 0 });
    });
    if (drawerRows.length === 0) {
        drawerRows.push({ eventId: '', filters: [], filterOpen: false });
    }
    document.getElementById('drawerOverlay').classList.add('show');
    document.getElementById('drawer').classList.add('open');
    renderDrawerBody();
}

function closeDrawer() {
    document.getElementById('drawerOverlay').classList.remove('show');
    document.getElementById('drawer').classList.remove('open');
    _openDropdownIdx = -1;
}

function validateDrawerRows(rows, prefix) {
    clearValidationErrors(prefix);
    var hasError = false;
    rows.forEach(function(row, idx) {
        var selectEl = document.getElementById(prefix + 'Select' + idx);
        if (!row.eventId) {
            if (selectEl) selectEl.classList.add('has-error');
            var tip = document.getElementById(prefix + 'Row' + idx);
            if (tip) {
                var errDiv = document.createElement('div');
                errDiv.className = 'ev-row-error-tip validation-error';
                errDiv.textContent = '请选择事件';
                tip.querySelector('.ev-row-main').insertAdjacentElement('afterend', errDiv);
            }
            hasError = true;
        }
        if (row.eventId && row.filters.length > 0) {
            row.filters.forEach(function(f, fi) {
                var filterRows = document.querySelectorAll('#' + prefix + 'Row' + idx + ' .ev-filter-row');
                var filterRow = filterRows && filterRows[fi];
                if (!filterRow) return;
                var selects = filterRow.querySelectorAll('select');
                var input = filterRow.querySelector('input');
                if (!f.attr) {
                    if (selects[0]) selects[0].classList.add('has-error');
