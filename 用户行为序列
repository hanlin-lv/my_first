            html += '<div class="ev-filter-area show">';
            html += '<div class="ev-filter-bracket">';
            if (row.filters.length > 0) {
                row.filters.forEach(function(f, fi) {
                    var attrOpts = '<option value="">请选择</option>' + ATTRS.map(function(a) {
                        return '<option value="' + a + '"' + (f.attr === a ? ' selected' : '') + '>' + a + '</option>';
                    }).join('');
                    var opOpts = OPS.map(function(o) {
                        return '<option value="' + o + '"' + (f.op === o ? ' selected' : '') + '>' + o + '</option>';
                    }).join('');
